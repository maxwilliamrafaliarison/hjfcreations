# ════════════════════════════════════════════════════════════════════════
# Variables d'environnement — copiez ce fichier en  .env.local  (local)
# et ajoutez les mêmes valeurs dans Vercel → Project → Settings →
# Environment Variables (pour la production).
#
# Les valeurs se trouvent dans Supabase → Project Settings → API Keys.
# ════════════════════════════════════════════════════════════════════════

# URL du projet Supabase (ex : https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clé publique « anon » (lecture du contenu + connexion admin)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé « service_role » — SECRÈTE, serveur uniquement (upload photos, seed).
# Ne jamais l'exposer côté client ni la committer.
SUPABASE_SERVICE_ROLE_KEY=

# Emails autorisés à accéder à /admin (séparés par des virgules)
ADMIN_EMAILS=hjcreation101@gmail.com,max.fianar@gmail.com
